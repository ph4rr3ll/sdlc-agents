{
  // JSON Schema для автокомплита в VS Code
  "$schema": "https://app.kilo.ai/config.json",

  // Дефолтные workspace permissions.
  // Per-agent permissions в .kilo/agents/<name>.md точнее и приоритетнее.
  //
  // Заметка по схеме v7.3+:
  // Агенты из .kilo/agents/*.md обнаруживаются автоматически — отдельный ключ
  // не нужен. Корневой ключ `agent` в kilo.jsonc — для INLINE конфигурации
  // встроенных агентов (plan/build/general/etc), не для наших wrapper'ов.
  "permission": {
    "read": "allow",
    "edit": {
      ".agent_space/**": "allow",
      "*": "ask"
    },
    "bash": "ask",
    "webfetch": "deny"
  }
}
