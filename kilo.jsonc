{
  // JSON Schema для автокомплита в VS Code
  "$schema": "https://app.kilo.ai/config.json",

  // Подключаем все агенты команды.
  // Каждый файл — тонкий wrapper, читающий полный манифест из .agents/
  "agents": [".kilo/agents/*.md"],

  // Дефолтные workspace permissions.
  // Per-agent permissions в .kilo/agents/<name>.md точнее и приоритетнее.
  "permission": {
    "read": "allow",
    "edit": {
      ".agent_space/**": "allow",
      "*": "ask"
    },
    "bash": "ask",
    "webfetch": "deny",
    "websearch": "deny"
  }
}
